---
interface NavItem {
  id: string;
  label: string;
}

interface Props {
  name: string;
  tagline: string;
  navItems: NavItem[];
}

const { name, tagline, navItems } = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <div class="identity">
      <h1>{name}</h1>
      <p class="tagline">{tagline}</p>
    </div>
    <nav aria-label="Section navigation">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={`#${item.id}`}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-color: var(--color-ink);
    color: var(--color-on-ink);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  h1 {
    font-size: 1.5rem;
    color: var(--color-on-ink);
  }

  .tagline {
    margin: 0.25rem 0 0 0;
    font-size: 0.95rem;
    color: #c7ccd4;
  }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
  }

  nav a {
    color: var(--color-on-ink);
    font-size: 0.9rem;
  }

  nav a:hover,
  nav a:focus-visible {
    color: #ffffff;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-2);
    }

    nav ul {
      gap: var(--space-2);
    }
  }
</style>
