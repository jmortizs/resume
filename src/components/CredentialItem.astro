---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  href?: string;
  subtitle: string;
  period: string;
  description?: string;
}

const { title, href, subtitle, period, description } = Astro.props;
---

<div class="credential-item">
  <h3>
    {
      href ? (
        <a href={href} target="_blank" rel="noopener noreferrer">
          {title} <Icon name="external" size={14} />
        </a>
      ) : (
        title
      )
    }
  </h3>
  {description && <p class="description">{description}</p>}
  <p class="meta">
    <span>{subtitle}</span> &middot; <span>{period}</span>
  </p>
</div>

<style>
  .credential-item + .credential-item {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  h3 {
    font-size: 1.05rem;
  }

  h3 a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .description {
    color: var(--color-text-muted);
    margin: var(--space-1) 0;
  }

  .meta {
    margin: 0;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-text-muted);
  }
</style>
