---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="skill-badge">{label}</span>

<style>
  .skill-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.85rem;
    background-color: var(--color-chip-bg);
    color: var(--color-ink-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.9rem;
  }
</style>
